---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import introVideo from '../assets/Intuitions.mp4';
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class="hero">
    <div class="hero-content">
      <div class="hero-title-row">
        <img src="/logo.png" class="hero-logo" alt="" />
        <h1 class="hero-title">intuitions</h1>
      </div>
      <div class="hero-body">
      <p class="hero-subtitle">{SITE_DESCRIPTION}</p>
      <div class="hero-video-container">
        <video src={introVideo} controls playsinline></video>
      </div>
      </div>
    </div>
  </section>
</BaseLayout>
